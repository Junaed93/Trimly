# MySQL Connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=fittrackbd

# JWT
JWT_SECRET=your_strong_random_secret_here

# Server
PORT=3000
